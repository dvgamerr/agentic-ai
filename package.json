{
  "name": "agentic-ai",
  "title": "Agentic AI",
  "type": "module",
  "version": "0.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "bun x --bun astro dev",
    "serv": "bun ./dist/server/entry.mjs",
    "build:dist": "bun x --bun astro build",
    "test": "bun x lint-staged && bun x commitlint",
    "prepare": "husky",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "npm run build:dist && electron-builder --win --config",
    "build:mac": "npm run build:dist && electron-builder --mac --config",
    "build:linux": "npm run build:dist && electron-builder --linux --config"
  },
  "lint-staged": {
    "*": "prettier --check . --write",
    "*.{js,mjs,svelte,astro}": "eslint --fix"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@lucide/svelte": "^1.8.0"
  },
  "devDependencies": {
    "@astrojs/node": "^10.0.5",
    "@astrojs/svelte": "^8.0.5",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@internationalized/date": "^3.12.0",
    "@nurodev/astro-bun": "^2.1.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.12",
    "astro": "^6.1.8",
    "astro-electron": "^0.5.0",
    "astro-google-fonts-optimizer": "^0.2.2",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "commitlint": "^20.5.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-log": "^5.4.3",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-eslint": "^16.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.55.4",
    "svelte-highlight": "^7.9.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "svelte": "dist/index.js",
  "private": true
}

---
import { GoogleFontsOptimizer } from 'astro-google-fonts-optimizer'
import { ClientRouter } from 'astro:transitions'
import '../styles/global.css'

import TitleBar from '../components/TitleBar.svelte'

const title = 'Agentic AI'
const THEME_NAME = 'app:theme'
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <GoogleFontsOptimizer url="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300..700&family=Sarabun:wght@400;700&family=Mulish:ital,wght@0,200..1000;1,200..1000&display=swap" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
  </head>
  <body class="bg-background text-foreground font-sans text-sm grid overflow-hidden h-[calc(100vh-1.2em)]">
    <TitleBar client:only="svelte" />
    <div id="desktop" class="overflow-auto flex flex-col">
      <div class="flex-1 overflow-auto">
        <slot />
      </div>
    </div>
  </body>
</html>

<script is:inline define:vars={{ THEME_NAME }}>
  console.log({ THEME_NAME })
</script>
<style>
  body {
    user-select: none;
    grid-template-areas:
      'title'
      'panel';
    grid-template-rows: [row1-start] var(--system-titleBar-height);
  }

  #desktop {
    grid-area: panel;
  }
</style>

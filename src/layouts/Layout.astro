---
import { GoogleFontsOptimizer } from 'astro-google-fonts-optimizer'
import { ClientRouter } from 'astro:transitions'
import { Layers, MessageSquare, Moon, Settings2, Sparkles } from '@lucide/svelte'
import '../styles/global.css'

const title = 'Hades AI'
const pathname = Astro.url.pathname
const navItems = [
  { href: '/#models', hash: '#models', label: 'Models', icon: Layers, active: pathname === '/' },
  { href: '/#memory', hash: '#memory', label: 'Memory', icon: MessageSquare, active: false },
  { href: '/#dream', hash: '#dream', label: 'Dream Cycle', icon: Moon, active: false },
  { href: '/#skills', hash: '#skills', label: 'Skills', icon: Sparkles, active: false },
]
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <GoogleFontsOptimizer url="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300..700&family=Sarabun:wght@400;700&family=Mulish:ital,wght@0,200..1000;1,200..1000&display=swap" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
  </head>
  <body class="text-foreground font-sans text-sm grid overflow-hidden h-[calc(100vh-1.2em)]">
    <div id="titlebar" class="select-none">
      <div class="bar w-full"></div>
    </div>

    <div id="desktop" class="flex min-h-0 flex-col">
      <div class="min-h-0 flex-1" style="margin-top: calc(var(--system-titleBar-height, 2.65em) * -1);">
        <div class="grid h-full min-h-0 gap-4 p-4" style="grid-template-columns: 200px 1fr;">
          <aside class="flex h-[calc(100%+1em)] flex-col gap-1 rounded-xl border border-border/60 bg-card/40 p-3">
            <div class="flex items-center gap-2 px-2 py-3">
              <img src="/logo.png" width="20" height="20" alt="logo" />
              <span class="text-sm font-semibold" style="font-family: 'Mulish'">Hades</span>
            </div>

            <nav class="mt-2 flex flex-col gap-0.5">
              {
                navItems.map((item) => {
                  const Icon = item.icon
                  return (
                    <a
                      href={item.href}
                      data-nav-link
                      data-nav-hash={item.hash}
                      aria-current={item.active ? 'page' : undefined}
                      class:list={[
                        'flex items-center gap-2.5 rounded-md px-3 py-2 text-left text-xs transition-colors nav-link',
                        item.active ? 'bg-primary/15 text-primary' : 'text-muted-foreground hover:bg-accent hover:text-foreground',
                      ]}
                    >
                      <Icon size={15} />
                      <span>{item.label}</span>
                    </a>
                  )
                })
              }
            </nav>

            <div class="mt-auto pt-3">
              <a
                href="/settings"
                data-settings-link
                class:list={[
                  'flex items-center gap-2.5 rounded-md px-3 py-2 text-left text-xs transition-colors nav-link',
                  pathname === '/settings' ? 'bg-primary/15 text-primary' : 'text-muted-foreground hover:bg-accent hover:text-foreground',
                ]}
              >
                <Settings2 size={15} />
                <span>Settings</span>
              </a>
            </div>
          </aside>

          <main class="app-scrollbar flex min-h-0 flex-col overflow-y-auto pr-1">
            <slot />
          </main>
        </div>
      </div>
    </div>
  </body>
</html>

<script>
  function syncAsideState() {
    const path = window.location.pathname
    const hash = window.location.hash || '#models'
    const navLinks = Array.from(document.querySelectorAll('[data-nav-link]'))
    const settingsLink = document.querySelector('[data-settings-link]')

    navLinks.forEach((link) => {
      const isDashboard = path === '/'
      const isActive = isDashboard && link.getAttribute('data-nav-hash') === hash
      link.classList.toggle('bg-primary/15', isActive)
      link.classList.toggle('text-primary', isActive)
      link.classList.toggle('text-muted-foreground', !isActive)
      link.setAttribute('aria-current', isActive ? 'page' : 'false')
    })

    if (settingsLink) {
      const isSettings = path === '/settings'
      settingsLink.classList.toggle('bg-primary/15', isSettings)
      settingsLink.classList.toggle('text-primary', isSettings)
      settingsLink.classList.toggle('text-muted-foreground', !isSettings)
      settingsLink.setAttribute('aria-current', isSettings ? 'page' : 'false')
    }
  }

  document.addEventListener('astro:page-load', syncAsideState)
  window.addEventListener('hashchange', syncAsideState)
</script>

<style>
  body {
    user-select: none;
    grid-template-areas:
      'title'
      'panel';
    grid-template-rows: [row1-start] var(--system-titleBar-height, 2.65em);
  }

  #titlebar {
    grid-area: title;
  }

  #desktop {
    grid-area: panel;
  }

  #titlebar .bar {
    -webkit-app-region: drag;
    height: var(--system-titleBar-height, 2.65em);
    background-color: var(--user-titlebar-background);
  }

  .nav-link[aria-current='page'] {
    background: color-mix(in srgb, var(--primary) 15%, transparent);
    color: var(--primary);
  }
</style>
